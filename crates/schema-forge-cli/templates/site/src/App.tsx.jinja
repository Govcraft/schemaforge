        <nav className="flex gap-4 text-sm text-muted-foreground">
          <Link to="/{{ entity.kebab }}">{{ entity.title }}</Link>
        </nav>
      </header>
      <main className="flex-1 p-6">
        <Routes>
          <Route path="/" element={<Navigate to="/{{ entity.kebab }}" replace />} />
