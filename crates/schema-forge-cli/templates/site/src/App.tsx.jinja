// App shell. The sidebar + topbar baseline lives here so every authed
// route shares one chrome — admin pages and per-entity /app pages alike
// — instead of double-stacking with AdminLayout. /login is the only
// route rendered outside the shell.
//
// The shell mirrors the Govcraft DS:
// - Sidebar (ink rail): brand mark + project name; an Admin section with
//   Schemas / Users entries; an Entities section listing every visible
//   schema with a per-row icon; a footer block with a quick-switcher
//   stub, a theme toggle, and an API/Build readout.
// - Topbar: chevron-separated breadcrumbs, a search-shaped command-K
//   button (palette is a follow-up; the button is the surface for it),
//   an icon-only theme toggle, and a user pill that signs out on click.
import type { ComponentType } from "react"
import { useEffect, useState } from "react"
import { Link, Navigate, Route, Routes, useLocation, useNavigate } from "react-router-dom"
import { useQuery } from "@tanstack/react-query"
import { Toaster } from "sonner"
import {
  Activity as ActivityIcon,
  Boxes,
  Building2,
  ChevronDown,
  ChevronRight,
  Contact,
  Database,
  FileText,
  Folder,
  Hash,
  Layers,
  ListTree,
  Moon,
  Search,
  Sun,
  Tag,
  Target,
  Users,
} from "lucide-react"
import { routeManifest } from "@/generated/route-manifest"
import { LoginPage } from "@/pages/login"
import { AdminLayout } from "@/admin/layout"
import { RequireAuth } from "@/lib/require-auth"
import { getCurrentUsername, isAuthenticated, logout } from "@/lib/auth"
import {
  getAdminPermissions,
  isSystemSchema,
  listSchemas,
  type SchemaResponse,
} from "@/admin/api-client"

const THEME_KEY = "{{ project_name | lower }}.theme"
type Theme = "light" | "dark"

function readTheme(): Theme {
  if (typeof window === "undefined") return "light"
  const stored = window.localStorage.getItem(THEME_KEY)
  if (stored === "dark" || stored === "light") return stored
  return window.matchMedia?.("(prefers-color-scheme: dark)").matches ? "dark" : "light"
}

function useTheme(): [Theme, () => void] {
  const [theme, setTheme] = useState<Theme>(() => readTheme())
  useEffect(() => {
    document.documentElement.setAttribute("data-theme", theme)
    window.localStorage.setItem(THEME_KEY, theme)
  }, [theme])
  return [theme, () => setTheme((t) => (t === "dark" ? "light" : "dark"))]
}

// ---------------------------------------------------------------------------
// Schema → icon mapping
// ---------------------------------------------------------------------------
//
// Keyed first by exact schema name (so domain-loaded schemas like
// `Company`, `Contact`, `Opportunity`, `Document` get the precise icon
// the design ships), then by a coarse keyword fallback for unknown
// schemas. Anything still unmatched falls through to a generic database
// glyph — better than no icon at all.
const SCHEMA_ICON_BY_NAME: Record<string, ComponentType<{ size?: number }>> = {
  Company: Building2,
  Organization: Building2,
  Department: Building2,
  Contact: Contact,
  Employee: Contact,
  User: Users,
  Opportunity: Target,
  Deal: Target,
  Document: FileText,
  Project: Folder,
  Task: ListTree,
  Milestone: Hash,
  Activity: ActivityIcon,
  Comment: FileText,
  Tag: Tag,
}

/** Convert a PascalCase schema name to its `/app/{kebab}` URL slug.
 *  Mirrors the conversion `schemaforge site generate` applies when
 *  emitting the route manifest: `Contact` → `contact`,
 *  `PullRequest` → `pull-request`. */
function pascalToKebab(name: string): string {
  return name.replace(/([a-z0-9])([A-Z])/g, "$1-$2").toLowerCase()
}

function pickIcon(name: string): ComponentType<{ size?: number }> {
  const exact = SCHEMA_ICON_BY_NAME[name]
  if (exact) return exact
  const lower = name.toLowerCase()
  if (lower.includes("user") || lower.includes("person")) return Users
  if (lower.includes("doc") || lower.includes("file")) return FileText
  if (lower.includes("event") || lower.includes("activity")) return ActivityIcon
  if (lower.includes("project") || lower.includes("folder")) return Folder
  if (lower.includes("tag") || lower.includes("label")) return Tag
  return Database
}

// ---------------------------------------------------------------------------
// Sidebar
// ---------------------------------------------------------------------------

function Sidebar({ theme, onToggleTheme }: { theme: Theme; onToggleTheme: () => void }) {
  const location = useLocation()
  // The schemas endpoint already filters to whatever the caller can read,
  // so the nav reflects Cedar's decision without any client-side
  // post-filtering. System schemas (User et al.) are still hidden from
  // the user-facing entities list — they're administered through dedicated
  // /admin/users surfaces, not the generic entity browser.
  const { data: schemas } = useQuery({
    queryKey: ["admin", "schemas"],
    queryFn: () => listSchemas(),
  })
  const appSchemas = (schemas ?? []).filter((s: SchemaResponse) => !isSystemSchema(s))

  // The admin shell's top-level sections (Schemas, Users) are gated by a
  // tiny dedicated endpoint so the nav matches what the underlying pages
  // would actually allow. A 401 from this query means the user is signed
  // out — that's already handled by the auth-aware `request()` helper.
  const { data: adminPerms } = useQuery({
    queryKey: ["admin", "permissions"],
    queryFn: getAdminPermissions,
  })
  const showSchemasAdmin = adminPerms?.admin.schemas_manage ?? false
  const showUsersAdmin = adminPerms?.admin.users_manage ?? false
  const showAdminSection = showSchemasAdmin || showUsersAdmin

  const isActive = (prefix: string) =>
    location.pathname === prefix || location.pathname.startsWith(prefix + "/")

  return (
    <aside className="shell-rail">
      <div className="rail-head">
        <img
          src="/logo-mark-white.svg"
          alt=""
          style={ { width: 26, height: 22, display: "block" }}
        />
        <div className="rail-title">{{ project_name }}</div>
      </div>

      {showAdminSection ? (
        <div className="rail-section">
          <div className="rail-section-label">
            <span>Admin</span>
          </div>
          {showSchemasAdmin ? (
            <Link
              to="/admin"
              className={"rail-link" + (location.pathname === "/admin" ? " active" : "")}
            >
              <Layers size={14} />
              <span>Schemas</span>
            </Link>
          ) : null}
          {showUsersAdmin ? (
            <Link
              to="/admin/users"
              className={"rail-link" + (isActive("/admin/users") ? " active" : "")}
            >
              <Users size={14} />
              <span>Users</span>
            </Link>
          ) : null}
        </div>
      ) : null}

      <div className="rail-section" style={ { flex: 1, minHeight: 0, overflow: "auto" }}>
        <div className="rail-section-label">
          <span>Entities</span>
          <span className="mono" style={ { color: "var(--app-rail-fg-3)" }}>
            {appSchemas.length}
          </span>
        </div>
        {appSchemas.map((s) => {
          const kebab = pascalToKebab(s.name)
          const Icon = pickIcon(s.name)
          return (
            <Link
              key={kebab}
              to={`/app/${kebab}`}
              className={"rail-link" + (isActive(`/app/${kebab}`) ? " active" : "")}
            >
              <Icon size={14} />
              <span>{s.name}</span>
            </Link>
          )
        })}
        {appSchemas.length === 0 ? (
          <div style={ { padding: "4px 8px", color: "var(--app-rail-fg-3)", fontSize: 12 }}>
            No application schemas yet.
          </div>
        ) : null}
      </div>

      <div>
        <div style={ { padding: "10px 12px 0" }}>
          <button
            type="button"
            className="rail-link"
            style={ { color: "var(--app-rail-fg-2)", width: "100%", textAlign: "left", background: "transparent", border: 0, font: "inherit" }}
            onClick={onToggleTheme}
            title={theme === "dark" ? "Light mode" : "Dark mode"}
          >
            {theme === "dark" ? <Sun size={14} /> : <Moon size={14} />}
            <span>{theme === "dark" ? "Light mode" : "Dark mode"}</span>
          </button>
        </div>
        <div className="rail-foot">
          <div className="rail-foot-line">
            <span>API</span>
            <span style={ { color: "var(--app-rail-fg-2)" }}>/api/v1/forge</span>
          </div>
          <div className="rail-foot-line">
            <span>Build</span>
            <span style={ { color: "var(--app-rail-fg-2)" }}>runtime</span>
          </div>
        </div>
      </div>
    </aside>
  )
}

// ---------------------------------------------------------------------------
// Topbar
// ---------------------------------------------------------------------------

function Topbar({ theme, onToggleTheme }: { theme: Theme; onToggleTheme: () => void }) {
  const location = useLocation()
  const navigate = useNavigate()
  const username = getCurrentUsername() ?? "user"

  // Build a tiny breadcrumb from the path. "/admin/Contact/abc/edit" →
  // [Admin, Contact, abc, Edit]. Plain CSS, no dependency on the route table.
  const segs = location.pathname.split("/").filter(Boolean)
  const crumbs = segs.length === 0 ? ["Home"] : segs

  return (
    <header className="shell-topbar">
      <nav className="crumbs" aria-label="breadcrumb">
        {crumbs.map((c, i) => (
          <span key={i} style={ { display: "inline-flex", alignItems: "center", gap: 6 }}>
            {i > 0 ? <ChevronRight size={12} className="sep" /> : null}
            <span className={i === crumbs.length - 1 ? "now" : ""}>{decodeURIComponent(c)}</span>
          </span>
        ))}
      </nav>

      <button
        type="button"
        className="topbar-search"
        onClick={() => navigate("/admin")}
        title="Jump to Schemas (⌘K palette: coming soon)"
      >
        <Search size={14} />
        <span className="grow">Search schemas, records…</span>
        <kbd>⌘</kbd>
        <kbd>K</kbd>
      </button>

      <button
        type="button"
        className="btn btn-icon btn-ghost"
        onClick={onToggleTheme}
        title={theme === "dark" ? "Light mode" : "Dark mode"}
      >
        {theme === "dark" ? <Sun size={14} /> : <Moon size={14} />}
      </button>

      <button type="button" className="topbar-user" onClick={logout} title="Sign out">
        <span className="avatar">{username.slice(0, 2).toUpperCase()}</span>
        <span>{username}</span>
        <ChevronDown size={12} />
      </button>
    </header>
  )
}

// Suppress unused-import lint when no schemas are loaded yet.
void Boxes

// ---------------------------------------------------------------------------
// Root
// ---------------------------------------------------------------------------

export default function App() {
  // Re-evaluate `isAuthenticated` on every navigation so the chrome
  // appears immediately after login (without the user needing to refresh).
  // The token lives in sessionStorage and isn't reactive on its own;
  // subscribing to `useLocation` re-renders App when the LoginPage calls
  // `navigate('/')` after a successful login, at which point the freshly
  // stored token flips this branch on.
  useLocation()
  const authed = isAuthenticated()
  const [theme, toggleTheme] = useTheme()

  if (!authed) {
    return (
      <Routes>
        <Route path="/login" element={<LoginPage />} />
        <Route
          path="*"
          element={
            <RequireAuth>
              <Navigate to="/admin" replace />
            </RequireAuth>
          }
        />
      </Routes>
    )
  }

  return (
    <div className="shell">
      <Sidebar theme={theme} onToggleTheme={toggleTheme} />
      <Topbar theme={theme} onToggleTheme={toggleTheme} />
      <main className="shell-main">
        <Routes>
          <Route path="/login" element={<LoginPage />} />

          {/* Land on the schema catalog: it's access-aware (filters to
              schemas the user can read) and never auto-loads a specific
              entity, so callers without read access on the first declared
              schema don't trigger a 403 popup before they've even chosen
              where to go. */}
          <Route
            path="/"
            element={
              <RequireAuth>
                <Navigate to="/admin" replace />
              </RequireAuth>
            }
          />

          {/* /app/*  — codegen'd per-entity pages. */}
          {routeManifest.map((r) => (
            <Route
              key={r.path}
              path={`/app/${r.path}`}
              element={
                <RequireAuth>
                  <r.element />
                </RequireAuth>
              }
            />
          ))}

          {/* /admin/* — generic schema-aware admin shell (runtime-dynamic). */}
          <Route
            path="/admin/*"
            element={
              <RequireAuth>
                <AdminLayout />
              </RequireAuth>
            }
          />
        </Routes>
      </main>
      <Toaster position="bottom-right" richColors closeButton />
    </div>
  )
}
