// Admin users create/edit form. Dual-purpose component behind both
// `/admin/users/new` and `/admin/users/:username/edit`:
//
// - **Create path** (no `:username`): POST /users with the whole form.
// - **Edit path** (`:username` present): username is read-only. Submitting
//   the form with a non-blank password calls `changePassword(username, ...)`.
//   Role editing is out of scope for v1 (there is no PUT /users/:username
//   endpoint yet) and the roles input is decorative on edit — submitting it
//   is a no-op. The `active` checkbox is likewise display-only on edit.
import { FormEvent, useEffect, useState } from "react"
import { Link, useNavigate, useParams } from "react-router-dom"
import { useMutation, useQuery } from "@tanstack/react-query"
import {
  changePassword,
  createUser,
  listUsers,
  type UserRow,
} from "@/admin/api-client"
import { Button } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { Input } from "@/components/ui/input"

type FormState = {
  username: string
  password: string
  rolesCsv: string
  active: boolean
}

const EMPTY: FormState = {
  username: "",
  password: "",
  rolesCsv: "",
  active: true,
}

export function UsersEdit() {
  const params = useParams<{ username?: string }>()
  const username = params.username
  const navigate = useNavigate()
  const isNew = !username

  const existing = useQuery({
    queryKey: ["admin", "users"],
    queryFn: listUsers,
    enabled: !isNew,
  })

  const [values, setValues] = useState<FormState>(EMPTY)
  const [formError, setFormError] = useState<string | null>(null)

  useEffect(() => {
    if (isNew) {
      setValues(EMPTY)
      return
    }
    if (existing.data && username) {
      const row: UserRow | undefined = existing.data.find(
        (u) => u.username === username,
      )
      if (row) {
        setValues({
          username: row.username,
          password: "",
          rolesCsv: row.roles.join(", "),
          active: row.active,
        })
      }
    }
  }, [isNew, existing.data, username])

  const save = useMutation({
    mutationFn: async (state: FormState) => {
      const roles = parseRoles(state.rolesCsv)
      if (isNew) {
        return createUser({
          username: state.username,
          password: state.password,
          roles,
          display_name: state.username,
        })
      }
      // Edit path: only the password is writable today.
      if (state.password.length > 0) {
        await changePassword(username!, state.password)
      }
      return null
    },
    onSuccess: () => navigate("/admin/users"),
  })

  if (!isNew && existing.isLoading) return <p>Loading…</p>

  function onSubmit(ev: FormEvent) {
    ev.preventDefault()
    setFormError(null)
    if (isNew) {
      if (values.username.trim() === "") {
        setFormError("Username is required")
        return
      }
      if (values.password.length < 8) {
        setFormError("Password must be at least 8 characters")
        return
      }
    } else if (values.password.length > 0 && values.password.length < 8) {
      setFormError("New password must be at least 8 characters")
      return
    }
    save.mutate(values)
  }

  return (
    <Card className="max-w-2xl">
      <CardHeader>
        <CardTitle>{isNew ? "New User" : `Edit User ${username}`}</CardTitle>
        <CardDescription>
          {isNew
            ? "Create a user with an initial password and role set."
            : "Leave the password blank to keep it unchanged."}
        </CardDescription>
      </CardHeader>
      <CardContent>
        <form onSubmit={onSubmit} className="space-y-4">
          <div className="grid grid-cols-[160px_1fr] gap-2 items-center">
            <label className="text-sm">username</label>
            <Input
              value={values.username}
              readOnly={!isNew}
              onChange={(e) =>
                setValues((prev) => ({ ...prev, username: e.target.value }))
              }
              placeholder="alice"
            />
          </div>

          <div className="grid grid-cols-[160px_1fr] gap-2 items-center">
            <label className="text-sm">
              password
              {isNew ? <span className="text-destructive"> *</span> : null}
            </label>
            <Input
              type="password"
              value={values.password}
              onChange={(e) =>
                setValues((prev) => ({ ...prev, password: e.target.value }))
              }
              placeholder={isNew ? "min 8 characters" : "leave blank to keep"}
            />
          </div>

          <div className="grid grid-cols-[160px_1fr] gap-2 items-start">
            <label className="text-sm pt-2">
              roles
              <div className="text-[10px] uppercase tracking-wide text-muted-foreground">
                comma-separated
              </div>
            </label>
            <div>
              <Input
                value={values.rolesCsv}
                onChange={(e) =>
                  setValues((prev) => ({ ...prev, rolesCsv: e.target.value }))
                }
                placeholder="admin, sales"
                disabled={!isNew}
              />
              {!isNew ? (
                <p className="text-[10px] text-muted-foreground mt-1">
                  role editing is not yet supported via REST
                </p>
              ) : null}
            </div>
          </div>

          <div className="grid grid-cols-[160px_1fr] gap-2 items-center">
            <label className="text-sm">active</label>
            <label className="inline-flex items-center gap-2 text-sm">
              <input
                type="checkbox"
                checked={values.active}
                disabled={!isNew}
                onChange={(e) =>
                  setValues((prev) => ({ ...prev, active: e.target.checked }))
                }
              />
              {!isNew ? (
                <span className="text-[10px] text-muted-foreground">
                  toggling active is not yet supported via REST
                </span>
              ) : null}
            </label>
          </div>

          {formError ? (
            <p className="text-destructive text-sm">{formError}</p>
          ) : null}
          {save.error ? (
            <p className="text-destructive text-sm">
              Save failed: {String(save.error)}
            </p>
          ) : null}

          <div className="flex gap-2 pt-2">
            <Button type="submit" disabled={save.isPending}>
              {save.isPending ? "Saving…" : isNew ? "Create" : "Save"}
            </Button>
            <Button variant="outline" asChild>
              <Link to="/admin/users">Cancel</Link>
            </Button>
          </div>
        </form>
      </CardContent>
    </Card>
  )
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function parseRoles(csv: string): string[] {
  return csv
    .split(",")
    .map((s) => s.trim())
    .filter((s) => s.length > 0)
}
