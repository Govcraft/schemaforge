// Admin users create/edit form. Dual-purpose component behind both
// `/admin/users/new` and `/admin/users/:username/edit`:
//
// - **Create path** (no `:username`): POST /users with username, password,
//   display_name, roles. The `active` checkbox is honoured at creation.
// - **Edit path** (`:username` present): username is read-only.
//   - display_name, roles, active are editable via PUT /users/:username
//     and submitted in a single mutation when the form is saved.
//   - password is editable via POST /users/:username/password and only
//     submitted when the field is non-blank.
import { FormEvent, useEffect, useState } from "react"
import { Link, useNavigate, useParams } from "react-router-dom"
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query"
import { toast } from "sonner"
import {
  changePassword,
  createUser,
  listRoles,
  listUsers,
  updateUser,
  type UserRow,
} from "@/admin/api-client"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"

type FormState = {
  username: string
  password: string
  displayName: string
  roles: string[]
  active: boolean
}

const EMPTY: FormState = {
  username: "",
  password: "",
  displayName: "",
  roles: [],
  active: true,
}

export function UsersEdit() {
  const params = useParams<{ username?: string }>()
  const username = params.username
  const navigate = useNavigate()
  const qc = useQueryClient()
  const isNew = !username

  const existing = useQuery({
    queryKey: ["admin", "users"],
    queryFn: listUsers,
    enabled: !isNew,
  })

  // Roles are operator-controlled at runtime via `policies/role_ranks.toml`,
  // so the form fetches the live catalog rather than baking it into the
  // generated bundle. The server filters out `platform_admin` for callers
  // that don't already hold it; we render whatever it returns.
  const rolesQuery = useQuery({
    queryKey: ["admin", "users", "roles"],
    queryFn: listRoles,
  })

  const [values, setValues] = useState<FormState>(EMPTY)
  const [initialActive, setInitialActive] = useState<boolean>(true)
  const [formError, setFormError] = useState<string | null>(null)

  useEffect(() => {
    if (isNew) {
      setValues(EMPTY)
      setInitialActive(true)
      return
    }
    if (existing.data && username) {
      const row: UserRow | undefined = existing.data.find(
        (u) => u.username === username,
      )
      if (row) {
        setValues({
          username: row.username,
          password: "",
          displayName: row.display_name ?? row.username,
          roles: row.roles,
          active: row.active,
        })
        setInitialActive(row.active)
      }
    }
  }, [isNew, existing.data, username])

  const save = useMutation({
    mutationFn: async (state: FormState) => {
      if (isNew) {
        return createUser({
          username: state.username,
          password: state.password,
          roles: state.roles,
          display_name:
            state.displayName.trim().length > 0
              ? state.displayName.trim()
              : state.username,
        })
      }
      // Edit path: PUT /users/:username with the editable fields, then
      // (separately) POST /users/:username/password if a password was
      // supplied. The password endpoint is its own resource because it
      // needs different access rules (self-service is allowed).
      await updateUser(username!, {
        roles: state.roles,
        display_name: state.displayName,
        active: state.active,
      })
      if (state.password.length > 0) {
        await changePassword(username!, state.password)
      }
      return null
    },
    onSuccess: () => {
      toast.success(isNew ? "Created user" : `Updated user '${username}'`)
      qc.invalidateQueries({ queryKey: ["admin", "users"] })
      navigate("/admin/users")
    },
  })

  if (!isNew && existing.isLoading) {
    return (
      <div className="page">
        <div className="empty">Loading…</div>
      </div>
    )
  }

  function onSubmit(ev: FormEvent) {
    ev.preventDefault()
    setFormError(null)
    if (isNew) {
      if (values.username.trim() === "") {
        setFormError("Username is required")
        return
      }
      if (values.password.length < 8) {
        setFormError("Password must be at least 8 characters")
        return
      }
    } else if (values.password.length > 0 && values.password.length < 8) {
      setFormError("New password must be at least 8 characters")
      return
    }
    save.mutate(values)
  }

  // The active checkbox shows a warning on edit when it would self-disable.
  const willDisableSelf =
    !isNew && initialActive && !values.active && username === "admin"

  return (
    <div className="page-narrow">
      <div className="page-head">
        <div>
          <div className="eyebrow">USER · {isNew ? "NEW" : "EDIT"}</div>
          <h1 className="page-title">
            {isNew ? "New user" : `Edit ${username}`}
          </h1>
          <div className="page-sub">
            {isNew
              ? "Create a user with an initial password and role set."
              : "Leave the password blank to keep it unchanged."}
          </div>
        </div>
      </div>

      <form onSubmit={onSubmit}>
        <div className="form-grid">
          <div className="form-row">
            <label className="form-label">username{isNew ? <span className="req">*</span> : null}</label>
            <div className="form-field">
              <Input
                value={values.username}
                readOnly={!isNew}
                onChange={(e) =>
                  setValues((prev) => ({ ...prev, username: e.target.value }))
                }
                placeholder="alice"
              />
            </div>
          </div>

          <div className="form-row">
            <label className="form-label">display name</label>
            <div className="form-field">
              <Input
                value={values.displayName}
                onChange={(e) =>
                  setValues((prev) => ({
                    ...prev,
                    displayName: e.target.value,
                  }))
                }
                placeholder="Alice Chen"
              />
            </div>
          </div>

          <div className="form-row">
            <label className="form-label">
              password
              {isNew ? <span className="req">*</span> : <span className="opt">optional</span>}
            </label>
            <div className="form-field">
              <Input
                type="password"
                value={values.password}
                onChange={(e) =>
                  setValues((prev) => ({ ...prev, password: e.target.value }))
                }
                placeholder={isNew ? "min 8 characters" : "leave blank to keep"}
              />
            </div>
          </div>

          <div className="form-row">
            <label className="form-label">roles</label>
            <div className="form-field">
              {rolesQuery.isLoading ? (
                <div className="help">loading roles…</div>
              ) : rolesQuery.isError ? (
                <div className="err mono" style={ { fontSize: 11 }}>
                  failed to load roles
                </div>
              ) : rolesQuery.data && rolesQuery.data.length > 0 ? (
                <div style={ { display: "flex", flexDirection: "column", gap: 6 }}>
                  {rolesQuery.data.map((role) => (
                    <label
                      key={role.name}
                      style={ {
                        display: "inline-flex",
                        alignItems: "center",
                        gap: 8,
                        fontSize: 13,
                      }}
                    >
                      <input
                        type="checkbox"
                        checked={values.roles.includes(role.name)}
                        onChange={(e) => {
                          const checked = e.target.checked
                          setValues((prev) => ({
                            ...prev,
                            roles: checked
                              ? [...prev.roles, role.name]
                              : prev.roles.filter((r) => r !== role.name),
                          }))
                        }}
                      />
                      <span className="mono">{role.name}</span>
                      <span className="help" style={ { marginLeft: "auto" }}>
                        rank {role.rank}
                      </span>
                    </label>
                  ))}
                </div>
              ) : (
                <div className="help">
                  no roles configured — see policies/role_ranks.toml
                </div>
              )}
            </div>
          </div>

          <div className="form-row">
            <label className="form-label">active</label>
            <div className="form-field">
              <label style={ { display: "inline-flex", alignItems: "center", gap: 8, fontSize: 13 }}>
                <input
                  type="checkbox"
                  checked={values.active}
                  onChange={(e) =>
                    setValues((prev) => ({ ...prev, active: e.target.checked }))
                  }
                />
                <span>{values.active ? "Active" : "Disabled"}</span>
              </label>
              {willDisableSelf ? (
                <div className="err mono" style={ { fontSize: 11 }}>
                  warning: disabling the bootstrap admin will lock the instance
                </div>
              ) : null}
            </div>
          </div>
        </div>

        {formError ? (
          <div
            role="alert"
            style={ {
              marginTop: 16,
              padding: "10px 14px",
              borderLeft: "2px solid var(--gc-err-400)",
              background: "rgba(180, 50, 26, 0.06)",
              color: "var(--gc-err-400)",
              fontSize: 13,
              borderRadius: 2,
            }}
          >
            {formError}
          </div>
        ) : null}

        <div style={ { display: "flex", gap: 8, marginTop: 24 }}>
          <Button type="submit" disabled={save.isPending}>
            {save.isPending ? "Saving…" : isNew ? "Create user" : "Save changes"}
          </Button>
          <Button variant="outline" asChild>
            <Link to="/admin/users">Cancel</Link>
          </Button>
        </div>
      </form>
    </div>
  )
}

