// Admin landing page. Stat tiles derived from the schema registry +
// schema cards grouped by application / system. Counts come straight
// from the catalog so the dashboard is honest about what it can show
// without paying for per-schema record-count round trips.
import { Link } from "react-router-dom"
import { useQuery } from "@tanstack/react-query"
import {
  listSchemas,
  isSystemSchema,
  type SchemaResponse,
  type FieldResponse,
} from "@/admin/api-client"
import { ErrorBlock } from "@/components/ui/error-block"

function isRelationField(f: FieldResponse): boolean {
  return f.field_type?.type === "Relation"
}

function fieldTypeLabel(f: FieldResponse): string {
  const t = f.field_type?.type ?? "?"
  if (t === "Relation") {
    const data = f.field_type?.data as { target?: string; cardinality?: string } | undefined
    return data?.target ? `→ ${data.target}` : "→ ?"
  }
  return t.toLowerCase()
}

function SchemaCard({ schema }: { schema: SchemaResponse }) {
  const fieldCount = schema.fields.length
  const relCount = schema.fields.filter(isRelationField).length
  const preview = schema.fields.slice(0, 4)
  return (
    <Link to={`/admin/${schema.name}`} className="schema-card">
      <div className="schema-card-head">
        <h3>{schema.name}</h3>
        <span className="meta">
          {fieldCount}F · {relCount}R
        </span>
      </div>
      <ul className="field-list">
        {preview.map((f) => (
          <li key={f.name}>
            <span>{f.name}</span>
            <span className="t">{fieldTypeLabel(f)}</span>
          </li>
        ))}
        {fieldCount > preview.length ? (
          <li>
            <span style={ { color: "var(--app-fg-4)" }}>… +{fieldCount - preview.length} more</span>
          </li>
        ) : null}
      </ul>
    </Link>
  )
}

function Stat({ k, v, d }: { k: string; v: string | number; d?: string }) {
  return (
    <div className="stat">
      <div className="k">{k}</div>
      <div className="v">{v}</div>
      {d ? <div className="d">{d}</div> : null}
    </div>
  )
}

export function SchemasIndex() {
  const query = useQuery({
    queryKey: ["admin", "schemas"],
    queryFn: () => listSchemas(),
  })
  const { data, isLoading, error } = query

  if (isLoading) {
    return (
      <div className="page">
        <div className="empty">Loading schemas…</div>
      </div>
    )
  }
  if (error) {
    return (
      <div className="page">
        <ErrorBlock
          title="Failed to load schemas"
          error={error}
          onRetry={() => query.refetch()}
        />
      </div>
    )
  }

  const schemas = data ?? []
  const appSchemas = schemas.filter((s) => !isSystemSchema(s))
  // Drop `User` from the System catalog: the dedicated /admin/users page
  // is the only sanctioned entry to user mgmt. Other system schemas stay
  // visible so operators can inspect TenantMembership, WebhookSubscription,
  // etc. through their generic CRUD surface.
  const systemSchemas = schemas.filter(
    (s) => isSystemSchema(s) && s.name !== "User",
  )

  const totalFields = schemas.reduce((acc, s) => acc + s.fields.length, 0)
  const totalRelations = schemas.reduce(
    (acc, s) => acc + s.fields.filter(isRelationField).length,
    0,
  )

  if (schemas.length === 0) {
    return (
      <div className="page">
        <div className="page-head">
          <div>
            <div className="eyebrow">SCHEMAS</div>
            <h1 className="page-title">Catalog</h1>
            <div className="page-sub">
              No schemas visible. Either the catalog is empty or your account
              lacks read permission.
            </div>
          </div>
        </div>
      </div>
    )
  }

  return (
    <div className="page">
      <div className="page-head">
        <div>
          <div className="eyebrow">DASHBOARD</div>
          <h1 className="page-title">Schema catalog</h1>
          <div className="page-sub">
            Application schemas you defined. System schemas are platform
            plumbing — managed via the dedicated routes when possible.
          </div>
        </div>
      </div>

      <div className="stat-grid mb-16" style={ { marginBottom: 16 }}>
        <Stat k="Schemas" v={schemas.length} d={`${appSchemas.length} application`} />
        <Stat k="Fields" v={totalFields} d="across all schemas" />
        <Stat k="Relations" v={totalRelations} d={`${(totalRelations / Math.max(schemas.length, 1)).toFixed(1)} avg`} />
        <Stat k="System" v={systemSchemas.length + 1} d="incl. User" />
      </div>

      {appSchemas.length > 0 && (
        <section style={ { marginBottom: 24 }}>
          <div className="eyebrow" style={ { marginBottom: 8 }}>Application</div>
          <div
            style={ {
              display: "grid",
              gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))",
              gap: 12,
            }}
          >
            {appSchemas.map((s) => (
              <SchemaCard key={s.name} schema={s} />
            ))}
          </div>
        </section>
      )}

      {systemSchemas.length > 0 && (
        <section>
          <div className="eyebrow" style={ { marginBottom: 8 }}>System</div>
          <div
            style={ {
              display: "grid",
              gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))",
              gap: 12,
            }}
          >
            {systemSchemas.map((s) => (
              <SchemaCard key={s.name} schema={s} />
            ))}
          </div>
        </section>
      )}
    </div>
  )
}
