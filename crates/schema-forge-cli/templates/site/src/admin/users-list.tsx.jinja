// Admin users list. Mirrors `entity-list.tsx` but against the dedicated
// `/api/v1/forge/users` endpoint instead of generic entity CRUD. The
// User entity table is reachable through this path and only this path —
// the generic `/admin/User` route redirects here.
import { Link, useNavigate } from "react-router-dom"
import { useMutation, useQuery, useQueryClient } from "@tanstack/react-query"
import { toast } from "sonner"
import { deleteUser, listUsers, type UserRow } from "@/admin/api-client"
import { Button } from "@/components/ui/button"
import { ErrorBlock } from "@/components/ui/error-block"

export function UsersList() {
  const navigate = useNavigate()
  const qc = useQueryClient()

  const users = useQuery({
    queryKey: ["admin", "users"],
    queryFn: listUsers,
  })

  const remove = useMutation({
    mutationFn: (username: string) => deleteUser(username),
    onSuccess: (_data, username) => {
      toast.success(`Deleted user '${username}'`)
      qc.invalidateQueries({ queryKey: ["admin", "users"] })
    },
  })

  if (users.isLoading) {
    return (
      <div className="page">
        <div className="empty">Loading…</div>
      </div>
    )
  }
  if (users.error) {
    return (
      <div className="page">
        <ErrorBlock
          title="Failed to load users"
          error={users.error}
          onRetry={() => users.refetch()}
        />
      </div>
    )
  }

  const rows = users.data ?? []
  const activeCount = rows.filter((u) => u.active).length

  return (
    <div className="page">
      <div className="page-head">
        <div>
          <div className="eyebrow">PEOPLE</div>
          <h1 className="page-title">Users</h1>
          <div className="page-sub">
            <span className="mono">{rows.length}</span> total ·{" "}
            <span className="mono">{activeCount}</span> active
          </div>
        </div>
        <Button onClick={() => navigate("/admin/users/new")}>New user</Button>
      </div>

      <div className="table-wrap" style={ { borderRadius: 2 }}>
        <table className="tbl">
          <thead>
            <tr>
              <th>username</th>
              <th>display name</th>
              <th>roles</th>
              <th style={ { textAlign: "right" }}>rank</th>
              <th>status</th>
              <th className="actioncell" />
            </tr>
          </thead>
          <tbody>
            {rows.map((u: UserRow) => (
              <tr key={u.username}>
                <td className="id-cell">
                  <Link to={`/admin/users/${encodeURIComponent(u.username)}/edit`}>
                    {u.username}
                  </Link>
                </td>
                <td>{u.display_name ?? <span className="muted">—</span>}</td>
                <td>
                  <div style={ { display: "inline-flex", gap: 4, flexWrap: "wrap" }}>
                    {u.roles.length === 0 ? (
                      <span className="muted">no roles</span>
                    ) : (
                      u.roles.map((r) => (
                        <span key={r} className="chip">
                          {r}
                        </span>
                      ))
                    )}
                  </div>
                </td>
                <td className="num" style={ { textAlign: "right" }}>
                  {u.role_rank === Number.MAX_SAFE_INTEGER ||
                  u.role_rank >= 9_223_372_036_854_775_000
                    ? "∞"
                    : u.role_rank.toLocaleString()}
                </td>
                <td>
                  {u.active ? (
                    <span className="chip chip-ok">active</span>
                  ) : (
                    <span className="chip chip-err">disabled</span>
                  )}
                </td>
                <td className="actioncell">
                  <div className="row-actions">
                    <Button variant="ghost" size="xs" asChild>
                      <Link to={`/admin/users/${encodeURIComponent(u.username)}/edit`}>
                        Edit
                      </Link>
                    </Button>
                    <Button
                      variant="ghost"
                      size="xs"
                      disabled={remove.isPending}
                      onClick={() => {
                        if (window.confirm(`Delete user '${u.username}'?`)) {
                          remove.mutate(u.username)
                        }
                      }}
                    >
                      Delete
                    </Button>
                  </div>
                </td>
              </tr>
            ))}
            {rows.length === 0 ? (
              <tr>
                <td colSpan={6}>
                  <div className="empty">
                    <h4>No users yet</h4>
                    <div>Add the first operator to get started.</div>
                  </div>
                </td>
              </tr>
            ) : null}
          </tbody>
        </table>
      </div>
    </div>
  )
}
