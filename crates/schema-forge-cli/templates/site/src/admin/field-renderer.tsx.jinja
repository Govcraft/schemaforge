// Generic field renderer shared across admin detail / edit / list views.
//
// Dispatches on `FieldMeta.kind` to the appropriate shadcn primitive. The
// read-only mode reuses the codegen'd `formatFieldValue`; the edit mode
// renders a controlled input that calls `onChange(next)` with the next
// value. Each kind is kept intentionally simple — fancier widgets
// (markdown preview, JSON linter, etc.) are a later polish pass.
import { useState, type ReactNode } from "react"
import { Input } from "@/components/ui/input"
import { RelationSelect } from "@/components/ui/relation-select"
import { formatFieldValue, type FieldDisplayHints } from "@/generated/formatters"
import type { FieldMeta } from "@/admin/api-client"
import { getCurrentRoles, hasAnyRole } from "@/lib/auth"

/**
 * Return true if the current user can read `field`. Fields without a
 * `@field_access(read=[...])` annotation are visible to everyone.
 */
export function canReadField(field: FieldMeta): boolean {
  if (!field.accessRead || field.accessRead.length === 0) return true
  return hasAnyRole(field.accessRead, getCurrentRoles())
}

/**
 * Return true if the current user can write `field`. Fields without a
 * `@field_access(write=[...])` annotation are writable by anyone with
 * read access.
 */
export function canWriteField(field: FieldMeta): boolean {
  if (!canReadField(field)) return false
  if (!field.accessWrite || field.accessWrite.length === 0) return true
  return hasAnyRole(field.accessWrite, getCurrentRoles())
}

export type FieldRendererProps = {
  field: FieldMeta
  value: unknown
  onChange?: (next: unknown) => void
  readOnly?: boolean
}

/** Read-only display: reuse the codegen'd formatter. */
function renderReadOnly(field: FieldMeta, value: unknown): ReactNode {
  if (field.kind === "composite" && field.subFields) {
    const obj = (value ?? {}) as Record<string, unknown>
    return (
      <div className="pl-3 border-l space-y-1">
        {field.subFields.map((sub) => (
          <div key={sub.name} className="grid grid-cols-[160px_1fr] gap-2 text-sm">
            <span className="text-muted-foreground">{sub.name}</span>
            <span>{renderReadOnly(sub, obj[sub.name])}</span>
          </div>
        ))}
      </div>
    )
  }
  // Map the admin's `kind` onto the formatter's narrower vocabulary, then
  // forward the field's `@widget` / `@format` hints so the formatter can
  // honor things like `currency`, `relative`, `progress`, etc.
  const hints: FieldDisplayHints = {
    kind: toFormatterKind(field.kind),
    widget: field.widget,
    format: field.format,
  }
  return <>{formatFieldValue(value, hints)}</>
}

/** Edit mode: controlled input keyed on kind. */
function renderEditor(
  field: FieldMeta,
  value: unknown,
  onChange: (next: unknown) => void,
): ReactNode {
  // Widget hints get first crack at dispatch so a `text` field annotated
  // with `@widget("richtext")` gets the textarea path instead of a single-
  // line input. Only the textarea-flavored hints are honored here; richer
  // widgets (markdown editor, WYSIWYG, etc.) are intentionally a later pass.
  if (field.widget === "richtext" || field.widget === "rich_text" || field.widget === "textarea") {
    if (field.kind === "text" || field.kind === "rich_text") {
      return (
        <textarea
          className="min-h-[120px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm"
          value={(value as string) ?? ""}
          onChange={(e) => onChange(e.target.value)}
        />
      )
    }
  }

  switch (field.kind) {
    case "text":
      return (
        <Input
          value={(value as string) ?? ""}
          onChange={(e) => onChange(e.target.value)}
        />
      )

    case "rich_text":
      return (
        <textarea
          className="min-h-[120px] w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm"
          value={(value as string) ?? ""}
          onChange={(e) => onChange(e.target.value)}
        />
      )

    case "integer":
      return (
        <Input
          type="number"
          step={1}
          value={(value as number | undefined) ?? ""}
          onChange={(e) => {
            const raw = e.target.value
            onChange(raw === "" ? null : Number.parseInt(raw, 10))
          }}
        />
      )

    case "float":
      return (
        <Input
          type="number"
          step="any"
          value={(value as number | undefined) ?? ""}
          onChange={(e) => {
            const raw = e.target.value
            onChange(raw === "" ? null : Number.parseFloat(raw))
          }}
        />
      )

    case "boolean":
      return (
        <input
          type="checkbox"
          className="h-4 w-4"
          checked={Boolean(value)}
          onChange={(e) => onChange(e.target.checked)}
        />
      )

    case "datetime": {
      const iso = typeof value === "string" ? value : ""
      // datetime-local wants `YYYY-MM-DDTHH:MM` (local tz, no seconds).
      const local = iso ? iso.slice(0, 16) : ""
      return (
        <Input
          type="datetime-local"
          value={local}
          onChange={(e) => {
            const raw = e.target.value
            if (!raw) {
              onChange(null)
              return
            }
            // Round-trip through Date so we emit a proper RFC 3339 string.
            const d = new Date(raw)
            onChange(isNaN(d.getTime()) ? null : d.toISOString())
          }}
        />
      )
    }

    case "enum":
      return (
        <select
          className="h-9 w-full rounded-md border border-input bg-transparent px-3 text-sm"
          value={(value as string) ?? ""}
          onChange={(e) => onChange(e.target.value || null)}
        >
          <option value="">— none —</option>
          {(field.enumVariants ?? []).map((v) => (
            <option key={v} value={v}>
              {v}
            </option>
          ))}
        </select>
      )

    case "relation_one":
      return field.relationTarget ? (
        <RelationSelect
          target={field.relationTarget}
          value={(value as string) ?? ""}
          onChange={(next) => onChange(next || null)}
        />
      ) : (
        <Input value="(missing relation target)" disabled />
      )

    case "relation_many": {
      // v1: comma-separated ids. A proper tag input is a later polish pass.
      const ids = Array.isArray(value) ? (value as string[]).join(", ") : ""
      return (
        <Input
          placeholder="id1, id2, id3"
          value={ids}
          onChange={(e) =>
            onChange(
              e.target.value
                .split(",")
                .map((s) => s.trim())
                .filter(Boolean),
            )
          }
        />
      )
    }

    case "json": {
      const pretty =
        value === undefined || value === null
          ? ""
          : JSON.stringify(value, null, 2)
      return (
        <textarea
          className="min-h-[140px] w-full rounded-md border border-input bg-transparent px-3 py-2 font-mono text-xs"
          value={pretty}
          onChange={(e) => {
            const raw = e.target.value
            if (raw.trim() === "") {
              onChange(null)
              return
            }
            try {
              onChange(JSON.parse(raw))
            } catch {
              // Keep the raw text around so the user can fix it; the submit
              // handler will re-parse and surface any residual error.
              onChange(raw)
            }
          }}
        />
      )
    }

    case "array": {
      // v1: JSON-array editor. Good enough for scalars and enum lists.
      const pretty = Array.isArray(value) ? JSON.stringify(value) : ""
      return (
        <Input
          placeholder='["a", "b", "c"]'
          value={pretty}
          onChange={(e) => {
            const raw = e.target.value
            try {
              onChange(raw.trim() === "" ? [] : JSON.parse(raw))
            } catch {
              onChange(raw)
            }
          }}
        />
      )
    }

    case "composite": {
      const obj = (value ?? {}) as Record<string, unknown>
      return (
        <fieldset className="border rounded p-3 space-y-2">
          {(field.subFields ?? []).map((sub) => (
            <div key={sub.name} className="grid grid-cols-[160px_1fr] gap-2 items-center">
              <label className="text-xs text-muted-foreground">
                {sub.name}
                {sub.required ? " *" : ""}
              </label>
              {renderEditor(sub, obj[sub.name], (next) =>
                onChange({ ...obj, [sub.name]: next }),
              )}
            </div>
          ))}
        </fieldset>
      )
    }

    case "file": {
      return (
        <FileFieldEditor
          field={field}
          value={value as FileAttachment | null | undefined}
          onChange={onChange as (next: FileAttachment | null) => void}
        />
      )
    }

    default:
      return <Input value={String(value ?? "")} disabled />
  }
}

/**
 * Persisted attachment shape. Matches the JSON the runtime emits via the
 * confirm-upload endpoint.
 */
type FileAttachment = {
  key: string
  size: number
  mime: string
  status: "pending" | "uploaded" | "scanning" | "available" | "quarantined" | "rejected"
  uploaded_at?: string
  checksum?: string
}

type FileFieldEditorProps = {
  field: FieldMeta
  value: FileAttachment | null | undefined
  onChange: (next: FileAttachment | null) => void
}

/**
 * Controlled editor for a `file` field. Implements the three-step flow:
 *
 *   1. POST ./upload-url to mint a presigned PUT.
 *   2. PUT bytes directly to object storage using the returned URL.
 *   3. POST ./confirm-upload to record the attachment on the entity.
 *
 * Progress is rendered with a native `<progress>` element and failures bubble
 * into an inline error panel so the admin UI does not silently swallow them.
 */
function FileFieldEditor({ field, value, onChange }: FileFieldEditorProps) {
  const [uploading, setUploading] = useState(false)
  const [progress, setProgress] = useState<number | null>(null)
  const [err, setErr] = useState<string | null>(null)

  const entityUrl = useEntityUrl()
  const fileMeta = field.fileMeta

  async function handleFile(file: File) {
    setErr(null)
    if (fileMeta?.maxSizeBytes && file.size > fileMeta.maxSizeBytes) {
      setErr(`File exceeds ${fileMeta.maxSizeHuman ?? `${fileMeta.maxSizeBytes} bytes`}.`)
      return
    }
    setUploading(true)
    setProgress(0)
    try {
      // Step 1 — mint presigned URL.
      const mintRes = await fetch(`${entityUrl}/fields/${field.name}/upload-url`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({
          filename: file.name,
          mime: file.type || "application/octet-stream",
          size: file.size,
        }),
      })
      if (!mintRes.ok) {
        throw new Error(`mint failed: ${mintRes.status} ${await safeBody(mintRes)}`)
      }
      const mint = (await mintRes.json()) as {
        upload_url: string
        key: string
        headers: Record<string, string>
      }

      // Step 2 — upload bytes with progress tracking via XHR (fetch streams
      // are widely supported but progress is still cleaner via XHR).
      await new Promise<void>((resolve, reject) => {
        const xhr = new XMLHttpRequest()
        xhr.open("PUT", mint.upload_url, true)
        for (const [k, v] of Object.entries(mint.headers)) xhr.setRequestHeader(k, v)
        xhr.upload.onprogress = (ev) => {
          if (ev.lengthComputable) setProgress(Math.round((ev.loaded / ev.total) * 100))
        }
        xhr.onload = () => (xhr.status >= 200 && xhr.status < 300 ? resolve() : reject(new Error(`upload failed: ${xhr.status}`)))
        xhr.onerror = () => reject(new Error("upload network error"))
        xhr.send(file)
      })

      // Step 3 — confirm and accept the runtime's attachment response.
      const confirmRes = await fetch(`${entityUrl}/fields/${field.name}/confirm-upload`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ key: mint.key }),
      })
      if (!confirmRes.ok) {
        throw new Error(`confirm failed: ${confirmRes.status} ${await safeBody(confirmRes)}`)
      }
      const confirm = (await confirmRes.json()) as { attachment: FileAttachment }
      onChange(confirm.attachment)
    } catch (e) {
      setErr(e instanceof Error ? e.message : String(e))
    } finally {
      setUploading(false)
      setProgress(null)
    }
  }

  return (
    <div className="space-y-2">
      {value?.key ? (
        <div className="flex items-center gap-2 text-sm">
          <span className="font-medium">{attachmentLabel(value)}</span>
          <StatusChip status={value.status} />
          {value.status === "available" ? (
            <a
              href={`${entityUrl}/fields/${field.name}`}
              target="_blank"
              rel="noreferrer"
              className="underline"
            >
              Download
            </a>
          ) : null}
          <button
            type="button"
            className="text-xs text-muted-foreground underline"
            onClick={() => onChange(null)}
          >
            Replace
          </button>
        </div>
      ) : (
        <input
          type="file"
          accept={fileMeta?.mimeAllowlist?.join(",")}
          disabled={uploading}
          onChange={(ev) => {
            const file = ev.target.files?.[0]
            if (file) void handleFile(file)
          }}
        />
      )}
      {fileMeta ? (
        <p className="text-xs text-muted-foreground">
          Up to {fileMeta.maxSizeHuman ?? `${fileMeta.maxSizeBytes} bytes`}. Allowed:{" "}
          {fileMeta.mimeAllowlist?.join(", ") ?? "any"}
        </p>
      ) : null}
      {progress !== null ? (
        <progress max={100} value={progress} className="w-full" />
      ) : null}
      {err ? <p className="text-sm text-destructive">{err}</p> : null}
    </div>
  )
}

function attachmentLabel(a: FileAttachment): string {
  const tail = a.key.split("/").pop() || a.key
  return `${tail} (${formatBytes(a.size)})`
}

function formatBytes(n: number): string {
  if (n < 1024) return `${n} B`
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`
  if (n < 1024 * 1024 * 1024) return `${(n / 1024 / 1024).toFixed(1)} MB`
  return `${(n / 1024 / 1024 / 1024).toFixed(2)} GB`
}

function StatusChip({ status }: { status: FileAttachment["status"] }) {
  const tone: Record<FileAttachment["status"], string> = {
    pending: "bg-yellow-100 text-yellow-800",
    uploaded: "bg-blue-100 text-blue-800",
    scanning: "bg-blue-100 text-blue-800",
    available: "bg-green-100 text-green-800",
    quarantined: "bg-red-100 text-red-800",
    rejected: "bg-red-100 text-red-800",
  }
  return (
    <span className={`text-xs px-1.5 py-0.5 rounded ${tone[status] ?? "bg-muted"}`}>
      {status}
    </span>
  )
}

async function safeBody(res: Response): Promise<string> {
  try {
    return await res.text()
  } catch {
    return ""
  }
}

/**
 * Returns the base URL for the current entity: `/api/v1/forge/schemas/{schema}/entities/{id}`.
 * The admin shell sets `window.__ENTITY_URL__` on the detail page so the
 * generic field renderer can reach the file endpoints without the schema/id
 * being passed down explicitly through React Hook Form state.
 */
function useEntityUrl(): string {
  // Best-effort — the admin shell always sets this for detail views. For list
  // views file cells are read-only (formatted via `renderReadOnly`) so this
  // path is not hit there.
  return (globalThis as unknown as { __ENTITY_URL__?: string }).__ENTITY_URL__ ?? ""
}

function toFormatterKind(kind: FieldMeta["kind"]) {
  switch (kind) {
    case "relation_one":
      return "relation_one" as const
    case "relation_many":
      return "relation_many" as const
    case "rich_text":
      return "rich_text" as const
    case "text":
    case "integer":
    case "float":
    case "boolean":
    case "datetime":
    case "enum":
    case "json":
    case "array":
      return kind
    default:
      return "text" as const
  }
}

export function FieldRenderer({
  field,
  value,
  onChange,
  readOnly,
}: FieldRendererProps) {
  // `@field_access(read=[...])`: hide the field entirely when the user
  // lacks a matching role. Callers that still render a wrapper (label,
  // grid row) should themselves check `canReadField` to avoid leaving
  // a dangling label.
  if (!canReadField(field)) return null
  // `@field_access(write=[...])`: downgrade to read-only regardless of
  // the caller's `readOnly` prop.
  const effectiveReadOnly = readOnly || !canWriteField(field)
  if (effectiveReadOnly || !onChange) {
    return <>{renderReadOnly(field, value)}</>
  }
  return <>{renderEditor(field, value, onChange)}</>
}
