// Auto-generated typed REST client.
// One set of CRUD functions per schema. Regenerated on every
// `schema-forge site generate` run.
import { refreshToken, tokenStore } from "@/lib/auth"
{%- for entity in entities %}
import type { {{ entity.pascal }} } from "./entity-types"
{%- endfor %}

const API_BASE = (import.meta.env.VITE_API_BASE as string | undefined) ?? ""

/// URL prefix for SchemaForge's versioned forge API. Kept as a constant so a
/// rename in the backend only touches one line.
const FORGE_API_PREFIX = "/api/v1/forge"

export type ListParams = {
  sort?: string
  limit?: number
  offset?: number
  /**
   * Per-field filter pairs. Keys use the backend's `<field>__<op>` syntax
   * (e.g. `name__contains`, `status__eq`, `age__gte`). Values are sent
   * verbatim as URL query parameters. Multiple entries AND-combine
   * server-side.
   */
  filters?: Record<string, string>
  /**
   * Opt out of the backend's parallel `COUNT(*)` query when `false`. The
   * envelope's `total_count` will be absent; callers that only read
   * `entities` (infinite scrolls, relation pickers, one-shot lookups)
   * should pass `false` here to skip the extra round trip. Defaults to
   * counting on.
   */
  count?: boolean
}

/** Schema-level permission flags computed by Cedar for the calling user.
 *  Drives "New" button visibility on list pages. */
export type SchemaPermissions = {
  create: boolean
}

/** Per-entity permission flags computed against the entity's actual
 *  attributes — `@owner` / `@tenant` style policies are honored. */
export type EntityPermissions = {
  update: boolean
  delete: boolean
}

export type ListResponse<T> = {
  /** Each item carries an optional `__permissions` companion field with
   *  the Cedar decision the server made for that row. */
  items: Array<T & { __permissions?: EntityPermissions }>
  total?: number
  /** Schema-level permissions for the caller (e.g., `create`). Absent
   *  when the server is older than the client. */
  permissions?: SchemaPermissions
}

async function request<T>(path: string, init?: RequestInit): Promise<T> {
  let res = await sendRequest(path, init)
  if (res.status === 401) {
    // Try to silently refresh the token once before giving up. If
    // refresh succeeds, replay the original request with the new
    // bearer; otherwise fall through to the login redirect.
    try {
      await refreshToken()
      res = await sendRequest(path, init)
    } catch {
      // Refresh failed — fall through to the 401 handler below.
    }
  }
  if (res.status === 401) {
    tokenStore.clear()
    if (typeof window !== "undefined") {
      const next = encodeURIComponent(window.location.pathname + window.location.search)
      window.location.replace(`/login?next=${next}`)
    }
    throw new Error("API 401: unauthorized")
  }
  if (!res.ok) {
    throw new Error(`API ${res.status}: ${await res.text()}`)
  }
  // 204 No Content: don't try to parse JSON.
  if (res.status === 204) {
    return undefined as T
  }
  return res.json() as Promise<T>
}

async function sendRequest(path: string, init?: RequestInit): Promise<Response> {
  const token = tokenStore.get()
  const headers: Record<string, string> = {
    "Content-Type": "application/json",
    ...((init?.headers as Record<string, string> | undefined) ?? {}),
  }
  if (token) {
    headers["Authorization"] = `Bearer ${token}`
  }
  return fetch(`${API_BASE}${path}`, { ...init, headers })
}

// ---------------------------------------------------------------------------
// Wire envelope translation
// ---------------------------------------------------------------------------
// The SchemaForge REST API wraps entity payloads in an envelope:
//   single:  { id, schema, fields: {...} }
//   list:    { entities: [{id, schema, fields}], count }
//   request: { fields: {...} }
// The generated client translates in both directions so pages see a flat
// entity shape with `id` at the top level.

type EntityEnvelope = {
  id: string
  schema: string
  fields: Record<string, unknown>
  permissions?: EntityPermissions
}

type ListEnvelope = {
  entities: EntityEnvelope[]
  count: number
  total_count?: number
  permissions?: SchemaPermissions
}

function flatten<T>(envelope: EntityEnvelope): T & { __permissions?: EntityPermissions } {
  // The `__permissions` companion is attached as a non-typed extra so
  // T-typed callers can opt to read it (`row.__permissions?.update`)
  // without every entity type having to declare the field. The
  // `unknown` step is only needed because TypeScript can't prove the
  // structural compatibility between `{id, ...fields}` and an arbitrary
  // T at this generic layer; runtime shape is what the backend serializes.
  const flat = { id: envelope.id, ...envelope.fields } as unknown as T & {
    __permissions?: EntityPermissions
  }
  if (envelope.permissions !== undefined) {
    flat.__permissions = envelope.permissions
  }
  return flat
}

function wrap(body: Record<string, unknown>): { fields: Record<string, unknown> } {
  // Strip `id` — the server owns it — and pass everything else as `fields`.
  const { id: _id, ...fields } = body
  void _id
  return { fields }
}

function listQuery(params: ListParams): string {
  const qs = new URLSearchParams()
  if (params.sort !== undefined) qs.set("sort", params.sort)
  if (params.limit !== undefined) qs.set("limit", String(params.limit))
  if (params.offset !== undefined) qs.set("offset", String(params.offset))
  if (params.filters !== undefined) {
    for (const [key, value] of Object.entries(params.filters)) {
      if (value !== "") qs.set(key, value)
    }
  }
  if (params.count === false) qs.set("count", "false")
  return qs.toString() ? `?${qs.toString()}` : ""
}

// ---------------------------------------------------------------------------
// Generic raw helpers (used by the relation combobox, which doesn't know
// the target schema's TS type at compile time).
// ---------------------------------------------------------------------------

export async function rawEntityList(
  schema: string,
  params: ListParams = { limit: 200 },
): Promise<Array<{ id: string } & Record<string, unknown>>> {
  // Relation pickers never read `total_count`, so opt out of the
  // backend's parallel `COUNT(*)` query. See GH issue #36.
  const envelope = await request<ListEnvelope>(
    `${FORGE_API_PREFIX}/schemas/${schema}/entities${listQuery({ ...params, count: false })}`,
  )
  return envelope.entities.map((e) => flatten(e))
}

// ---------------------------------------------------------------------------
// Typed per-schema CRUD
// ---------------------------------------------------------------------------
{% for entity in entities %}
export async function list{{ entity.pascal_plural }}(params: ListParams = {}): Promise<ListResponse<{{ entity.pascal }}>> {
  const envelope = await request<ListEnvelope>(
    `${FORGE_API_PREFIX}/schemas/{{ entity.schema_name }}/entities${listQuery(params)}`,
  )
  return {
    items: envelope.entities.map((e) => flatten<{{ entity.pascal }}>(e)),
    total: envelope.total_count ?? envelope.count,
    permissions: envelope.permissions,
  }
}

export async function get{{ entity.pascal }}(id: string): Promise<{{ entity.pascal }} & { __permissions?: EntityPermissions }> {
  const envelope = await request<EntityEnvelope>(
    `${FORGE_API_PREFIX}/schemas/{{ entity.schema_name }}/entities/${encodeURIComponent(id)}`,
  )
  return flatten<{{ entity.pascal }}>(envelope)
}

export async function create{{ entity.pascal }}(body: Partial<{{ entity.pascal }}>): Promise<{{ entity.pascal }}> {
  const envelope = await request<EntityEnvelope>(
    `${FORGE_API_PREFIX}/schemas/{{ entity.schema_name }}/entities`,
    {
      method: "POST",
      body: JSON.stringify(wrap(body as Record<string, unknown>)),
    },
  )
  return flatten<{{ entity.pascal }}>(envelope)
}

export async function update{{ entity.pascal }}(
  id: string,
  body: Partial<{{ entity.pascal }}>,
): Promise<{{ entity.pascal }}> {
  const envelope = await request<EntityEnvelope>(
    `${FORGE_API_PREFIX}/schemas/{{ entity.schema_name }}/entities/${encodeURIComponent(id)}`,
    {
      method: "PATCH",
      body: JSON.stringify(wrap(body as Record<string, unknown>)),
    },
  )
  return flatten<{{ entity.pascal }}>(envelope)
}

export async function delete{{ entity.pascal }}(id: string): Promise<void> {
  await request<void>(
    `${FORGE_API_PREFIX}/schemas/{{ entity.schema_name }}/entities/${encodeURIComponent(id)}`,
    { method: "DELETE" },
  )
}
{% endfor %}
