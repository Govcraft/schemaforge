// Schema-driven scaffold for the {{ entity.title }} detail page — always
// regenerated from the `.schema` file. This file carries the read-only
// row rendering that has to stay in lock-step with the schema. The
// sibling `detail.tsx` preserve file imports this component and composes
// it into the final page, so users can customize layout, section
// headers, and surrounding widgets there without ever touching the
// schema-shaped data here.
//
// Each field renders as a `<div className="spec-row">` block — the
// preserve file wraps the whole component in `<div className="spec">`
// so the 3-column § / label / value grid lights up automatically.
{%- if entity.has_relation_link %}
import { Link } from "react-router-dom"
{%- endif %}
{%- if entity.has_file_field %}
import { AttachmentDownload, type FileAttachment } from "@/components/ui/file-upload"
{%- endif %}
import type { {{ entity.pascal }} } from "@/generated/entity-types"
import { formatFieldValue } from "@/generated/formatters"

function specNum(n: number): string {
  return String(n).padStart(2, "0")
}

function isEmpty(v: unknown): boolean {
  if (v === null || v === undefined) return true
  if (typeof v === "string" && v.trim() === "") return true
  if (Array.isArray(v) && v.length === 0) return true
  return false
}

export function {{ entity.pascal }}DetailRows({ data }: { data: {{ entity.pascal }} }) {
  return (
    <>
{%- for f in entity.fields %}
{%- set num = loop.index %}
{%- if f.kind == "composite" %}
      <div className="spec-row">
        <div className="spec-num">§ {specNum({{ num }})}</div>
        <div className="spec-key">{{ f.label | upper }}</div>
        <div className="spec-val">
          <div
            style={ {
              display: "grid",
              gridTemplateColumns: "180px 1fr",
              rowGap: 4,
              columnGap: 12,
              fontSize: 13,
            }}
          >
{%- for sub in f.sub_fields %}
            <span
              className="mono"
              style={ {
                textTransform: "uppercase",
                letterSpacing: "0.06em",
                color: "var(--app-fg-3)",
                fontSize: 11,
              }}
            >
              {{ sub.label }}
            </span>
            <span>
              {formatFieldValue(
                (data as unknown as Record<string, unknown>)["{{ f.leaf }}"] &&
                  ((data as unknown as Record<string, unknown>)["{{ f.leaf }}"] as Record<string, unknown>)["{{ sub.leaf }}"],
                {
                  kind: "{{ sub.kind }}",
{%- if sub.widget %}
                  widget: "{{ sub.widget }}",
{%- endif %}
{%- if sub.format %}
                  format: "{{ sub.format }}",
{%- endif %}
                },
              )}
            </span>
{%- endfor %}
          </div>
        </div>
      </div>
{%- elif f.kind == "file" %}
      <div className="spec-row">
        <div className="spec-num">§ {specNum({{ num }})}</div>
        <div className="spec-key">{{ f.label | upper }}</div>
        <div className="spec-val">
          {(() => {
            const att = data.{{ f.leaf }} as FileAttachment | null | undefined
            if (!att || !att.key) return <span className="empty">— empty</span>
            return (
              <AttachmentDownload
                schema="{{ entity.schema_name }}"
                entityId={data.id}
                fieldName="{{ f.name }}"
                attachment={att}
                access="{{ f.file_meta.access }}"
              />
            )
          })()}
        </div>
      </div>
{%- elif f.kind == "relation_one" and f.relation_display_field %}
      <div className="spec-row">
        <div className="spec-num">§ {specNum({{ num }})}</div>
        <div className="spec-key">{{ f.label | upper }}</div>
        <div className="spec-val">
          {data.{{ f.leaf }} ? (
            <Link
              style={ { color: "var(--link)", textDecoration: "none" }}
              to={`/app/{{ f.relation_target_kebab }}/${data.{{ f.leaf }}}`}
            >
              {data.{{ f.leaf }}__display ?? data.{{ f.leaf }}}
            </Link>
          ) : (
            <span className="empty">— empty</span>
          )}
        </div>
      </div>
{%- elif f.kind == "relation_many" and f.relation_display_field %}
      <div className="spec-row">
        <div className="spec-num">§ {specNum({{ num }})}</div>
        <div className="spec-key">{{ f.label | upper }}</div>
        <div className="spec-val">
          {(() => {
            const ids = (data.{{ f.leaf }} ?? []) as string[]
            const labels = (data.{{ f.leaf }}__display ?? []) as (string | null)[]
            if (ids.length === 0) return <span className="empty">— empty</span>
            return (
              <span>
                {ids.map((id, i) => (
                  <span key={id}>
                    {i > 0 ? ", " : ""}
                    <Link
                      style={ { color: "var(--link)", textDecoration: "none" }}
                      to={`/app/{{ f.relation_target_kebab }}/${id}`}
                    >
                      {labels[i] ?? id}
                    </Link>
                  </span>
                ))}
              </span>
            )
          })()}
        </div>
      </div>
{%- else %}
      <div className="spec-row">
        <div className="spec-num">§ {specNum({{ num }})}</div>
        <div className="spec-key">{{ f.label | upper }}</div>
        <div className="spec-val">
          {isEmpty(data.{{ f.leaf }}) ? (
            <span className="empty">— empty</span>
          ) : (
            formatFieldValue(data.{{ f.leaf }}, {
              kind: "{{ f.kind }}",
{%- if f.widget %}
              widget: "{{ f.widget }}",
{%- endif %}
{%- if f.format %}
              format: "{{ f.format }}",
{%- endif %}
            })
          )}
        </div>
      </div>
{%- endif %}
{%- endfor %}
    </>
  )
}
