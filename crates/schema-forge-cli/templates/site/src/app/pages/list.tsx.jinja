// Scaffolded once by `schema-forge site generate` — edit freely.
// Subsequent runs will NOT overwrite this file unless --force-user-files is passed.
//
// Schema-driven pieces (`columns`, `SORTABLE_FIELDS`, `FILTERABLE_FIELDS`,
// `ENUM_COLORS`) live in the sibling `list.generated.tsx`, which is always
// regenerated from the schema. Reference them here to stay in sync with
// schema changes while keeping your layout, charts, and custom state in
// this preserve file.
//
// Layout follows the Govcraft DS: eyebrow + page title, mono toolbar with
// field-targeted contains filter, compact 32px-row table with mono
// uppercase headers + signal-orange sort arrows, hairline pager.
import { useEffect, useMemo, useState } from "react"
import { Link } from "react-router-dom"
import { keepPreviousData, useQuery } from "@tanstack/react-query"
import {
  useReactTable,
  getCoreRowModel,
  flexRender,
} from "@tanstack/react-table"
import { list{{ entity.pascal_plural }} } from "@/generated/api-client"
import { ErrorBlock } from "@/components/ui/error-block"
import {
  columns,
  SORTABLE_FIELDS,
  FILTERABLE_FIELDS,
} from "./list.generated"

const PAGE_SIZES = [25, 50, 100, 200] as const
type SortDir = "asc" | "desc"

export function {{ entity.pascal }}List() {
  const [limit, setLimit] = useState<number>(50)
  const [offset, setOffset] = useState<number>(0)
  const [sortField, setSortField] = useState<string | null>(null)
  const [sortDir, setSortDir] = useState<SortDir>("asc")
  const [filterField, setFilterField] = useState<string>(
    FILTERABLE_FIELDS[0] ?? "",
  )
  const [filterInput, setFilterInput] = useState<string>("")
  const [filterValue, setFilterValue] = useState<string>("")

  // Debounce the filter input so keystrokes don't stampede the backend.
  useEffect(() => {
    const t = setTimeout(() => {
      setFilterValue(filterInput)
      setOffset(0)
    }, 300)
    return () => clearTimeout(t)
  }, [filterInput])

  const sortParam = sortField
    ? sortDir === "desc"
      ? `-${sortField}`
      : sortField
    : undefined

  const filters =
    filterField && filterValue
      ? { [`${filterField}__contains`]: filterValue }
      : undefined

  const query = useQuery({
    queryKey: [
      "{{ entity.snake }}",
      "list",
      { limit, offset, sort: sortParam, filters },
    ],
    queryFn: () =>
      list{{ entity.pascal_plural }}({
        limit,
        offset,
        sort: sortParam,
        filters,
      }),
    placeholderData: keepPreviousData,
  })
  const { data, isLoading, error } = query

  const rows = useMemo(() => data?.items ?? [], [data])
  const total = data?.total ?? 0
  const pageStart = total === 0 ? 0 : offset + 1
  const pageEnd = Math.min(offset + rows.length, total)

  const table = useReactTable({
    data: rows,
    columns,
    getCoreRowModel: getCoreRowModel(),
  })

  function toggleSort(fieldName: string) {
    if (!SORTABLE_FIELDS.includes(fieldName)) return
    if (sortField !== fieldName) {
      setSortField(fieldName)
      setSortDir("asc")
    } else if (sortDir === "asc") {
      setSortDir("desc")
    } else {
      setSortField(null)
      setSortDir("asc")
    }
    setOffset(0)
  }

  return (
    <div className="page">
      <div className="page-head">
        <div>
          <div className="eyebrow">ENTITY</div>
          <h1 className="page-title">{{ entity.title }}</h1>
          <div className="page-sub">
            <span className="mono">{total.toLocaleString()}</span> total
          </div>
        </div>
        <div style={ { display: "flex", gap: 8 }}>
          <Link to="/app/{{ entity.kebab }}/new" className="btn btn-primary">
            New {{ entity.title }}
          </Link>
        </div>
      </div>

      <div className="toolbar">
        {FILTERABLE_FIELDS.length > 0 ? (
          <>
            <select
              className="toolbar-select"
              value={filterField}
              onChange={(e) => setFilterField(e.target.value)}
            >
              {FILTERABLE_FIELDS.map((f) => (
                <option key={f} value={f}>
                  {f}
                </option>
              ))}
            </select>
            <div className="toolbar-input" style={ { flex: "0 1 320px" }}>
              <span
                className="mono"
                style={ { color: "var(--app-fg-4)", fontSize: 11 }}
              >
                contains
              </span>
              <input
                placeholder="filter…"
                value={filterInput}
                onChange={(e) => setFilterInput(e.target.value)}
              />
            </div>
          </>
        ) : null}
        <span className="grow" />
        <select
          className="toolbar-select"
          value={limit}
          onChange={(e) => {
            setLimit(Number(e.target.value))
            setOffset(0)
          }}
          aria-label="Rows per page"
        >
          {PAGE_SIZES.map((size) => (
            <option key={size} value={size}>
              {size} / page
            </option>
          ))}
        </select>
      </div>

      <div className="table-wrap">
        <table className="tbl">
          <thead>
            {table.getHeaderGroups().map((hg) => (
              <tr key={hg.id}>
                {hg.headers.map((h) => {
                  const field = h.column.id
                  const sortable = SORTABLE_FIELDS.includes(field)
                  const active = sortField === field
                  const arrow = active ? (sortDir === "asc" ? " ↑" : " ↓") : ""
                  return (
                    <th key={h.id}>
                      {sortable ? (
                        <button type="button" onClick={() => toggleSort(field)}>
                          {flexRender(h.column.columnDef.header, h.getContext())}
                          {active ? <span className="sort-arrow">{arrow}</span> : null}
                        </button>
                      ) : (
                        flexRender(h.column.columnDef.header, h.getContext())
                      )}
                    </th>
                  )
                })}
              </tr>
            ))}
          </thead>
          <tbody>
            {isLoading && rows.length === 0 ? (
              <tr>
                <td colSpan={columns.length}>
                  <div className="empty">Loading…</div>
                </td>
              </tr>
            ) : null}
            {error && rows.length === 0 ? (
              <tr>
                <td colSpan={columns.length}>
                  <ErrorBlock
                    title="Failed to load"
                    error={error}
                    onRetry={() => query.refetch()}
                  />
                </td>
              </tr>
            ) : null}
            {table.getRowModel().rows.map((row) => (
              <tr key={row.id}>
                {row.getVisibleCells().map((cell) => (
                  <td key={cell.id}>
                    {cell.column.columnDef.cell
                      ? flexRender(cell.column.columnDef.cell, cell.getContext())
                      : String(cell.getValue() ?? "")}
                  </td>
                ))}
              </tr>
            ))}
            {!isLoading && !error && rows.length === 0 ? (
              <tr>
                <td colSpan={columns.length}>
                  <div className="empty">
                    <h4>No {{ entity.title }} records</h4>
                    <div>Create one to get started, or relax your filter.</div>
                  </div>
                </td>
              </tr>
            ) : null}
          </tbody>
        </table>
      </div>

      <div className="pager">
        <div className="group">
          <span className="mono">
            {total === 0 ? "0 of 0" : `${pageStart}–${pageEnd} of ${total}`}
          </span>
        </div>
        <div className="group">
          <button
            type="button"
            className="btn btn-sm"
            disabled={offset === 0}
            onClick={() => setOffset(Math.max(0, offset - limit))}
          >
            Prev
          </button>
          <button
            type="button"
            className="btn btn-sm"
            disabled={pageEnd >= total}
            onClick={() => setOffset(offset + limit)}
          >
            Next
          </button>
        </div>
      </div>
    </div>
  )
}
