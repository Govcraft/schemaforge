// Scaffolded once by `schema-forge site generate` — edit freely.
// Subsequent runs will NOT overwrite this file unless --force-user-files is passed.
//
// Schema-driven detail rows live in the sibling `detail.generated.tsx`,
// which is always regenerated from the schema. Reference the exported
// `<{{ entity.pascal }}DetailRows>` component here so schema changes flow
// through automatically while your layout and surrounding widgets stay
// put in this preserve file.
//
// Layout follows the Govcraft "spec sheet": a 56px § margin column
// alongside mono uppercase labels and the rendered value, with hairline
// row dividers. Edit/Back actions live in the page header.
import { Link, useParams } from "react-router-dom"
import { useQuery } from "@tanstack/react-query"
import { get{{ entity.pascal }} } from "@/generated/api-client"
import { ErrorBlock } from "@/components/ui/error-block"
import { {{ entity.pascal }}DetailRows } from "./detail.generated"

export function {{ entity.pascal }}Detail() {
  const { id } = useParams<{ id: string }>()
  const query = useQuery({
    queryKey: ["{{ entity.snake }}", "detail", id],
    queryFn: () => get{{ entity.pascal }}(id!),
    enabled: Boolean(id),
  })
  const { data, isLoading, error } = query

  if (isLoading) {
    return (
      <div className="page">
        <div className="empty">Loading…</div>
      </div>
    )
  }
  if (error || !data) {
    return (
      <div className="page">
        <ErrorBlock
          title="Failed to load record"
          error={error ?? new Error("record not found")}
          onRetry={() => query.refetch()}
        />
      </div>
    )
  }

  // Pick the most "human" field for the page title — name/title/label
  // first, fall back to the id. Keeps the spec sheet feeling like a record.
  const headline =
    pickHeadline(data as unknown as Record<string, unknown>) ?? data.id

  // Edit visibility tracks the Cedar `Update` decision the server already
  // computed against this record's actual attributes; default to hidden
  // when the field is absent (older server, etc.).
  const canUpdate = data.__permissions?.update ?? false

  return (
    <div className="page-narrow">
      <div className="page-head">
        <div>
          <div className="eyebrow">{{ entity.title | upper }} · RECORD</div>
          <h1 className="page-title">{headline}</h1>
          <div className="page-sub mono">{data.id}</div>
        </div>
        <div style={ { display: "flex", gap: 8 }}>
          <Link to="/app/{{ entity.kebab }}" className="btn">Back</Link>
          {canUpdate ? (
            <Link to={`/app/{{ entity.kebab }}/${data.id}/edit`} className="btn btn-primary">
              Edit
            </Link>
          ) : null}
        </div>
      </div>

      <div className="spec">
        <{{ entity.pascal }}DetailRows data={data} />
      </div>
    </div>
  )
}

function pickHeadline(data: Record<string, unknown>): string | undefined {
  const candidates = ["name", "title", "label", "subject", "username", "email"]
  for (const k of candidates) {
    const v = data[k]
    if (typeof v === "string" && v.trim()) return v
  }
  return undefined
}
