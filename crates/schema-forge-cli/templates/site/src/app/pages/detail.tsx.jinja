// Scaffolded once by `schema-forge site generate` — edit freely.
import { Link, useParams } from "react-router-dom"
import { useQuery } from "@tanstack/react-query"
import { get{{ entity.pascal }} } from "@/generated/api-client"
import { formatFieldValue } from "@/generated/formatters"
import { Button } from "@/components/ui/button"
import { ErrorBlock } from "@/components/ui/error-block"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"

export function {{ entity.pascal }}Detail() {
  const { id } = useParams<{ id: string }>()
  const query = useQuery({
    queryKey: ["{{ entity.snake }}", "detail", id],
    queryFn: () => get{{ entity.pascal }}(id!),
    enabled: Boolean(id),
  })
  const { data, isLoading, error } = query

  if (isLoading) return <p>Loading…</p>
  if (error || !data) {
    return (
      <ErrorBlock
        title="Failed to load record"
        error={error ?? new Error("record not found")}
        onRetry={() => query.refetch()}
      />
    )
  }

  return (
    <Card className="max-w-2xl">
      <CardHeader>
        <CardTitle>{{ entity.title }} — {data.id}</CardTitle>
        <CardDescription>Read-only detail view. Generated by schema-forge.</CardDescription>
      </CardHeader>
      <CardContent className="space-y-3">
{%- for f in entity.fields %}
{%- if f.kind == "composite" %}
        <div className="pt-2">
          <div className="text-xs uppercase tracking-wide text-muted-foreground mb-1">
            {{ f.label }}
          </div>
          <div className="pl-3 border-l space-y-1">
{%- for sub in f.sub_fields %}
            <div className="grid grid-cols-[160px_1fr] gap-2 text-sm">
              <span className="text-muted-foreground">{{ sub.label }}</span>
              <span>
                {formatFieldValue(
                  (data as unknown as Record<string, unknown>)["{{ f.leaf }}"] &&
                    ((data as unknown as Record<string, unknown>)["{{ f.leaf }}"] as Record<string, unknown>)["{{ sub.leaf }}"],
                  {
                    kind: "{{ sub.kind }}",
{%- if sub.widget %}
                    widget: "{{ sub.widget }}",
{%- endif %}
{%- if sub.format %}
                    format: "{{ sub.format }}",
{%- endif %}
                  },
                )}
              </span>
            </div>
{%- endfor %}
          </div>
        </div>
{%- elif f.kind == "relation_one" and f.relation_display_field %}
        <div className="grid grid-cols-[160px_1fr] gap-2 text-sm">
          <span className="text-muted-foreground">{{ f.label }}</span>
          <span>
            {data.{{ f.leaf }} ? (
              <Link className="underline" to={`/app/{{ f.relation_target_kebab }}/${data.{{ f.leaf }}}`}>
                {data.{{ f.leaf }}__display ?? data.{{ f.leaf }}}
              </Link>
            ) : (
              <span className="text-muted-foreground">—</span>
            )}
          </span>
        </div>
{%- elif f.kind == "relation_many" and f.relation_display_field %}
        <div className="grid grid-cols-[160px_1fr] gap-2 text-sm">
          <span className="text-muted-foreground">{{ f.label }}</span>
          <span>
            {(() => {
              const ids = (data.{{ f.leaf }} ?? []) as string[]
              const labels = (data.{{ f.leaf }}__display ?? []) as (string | null)[]
              if (ids.length === 0) return <span className="text-muted-foreground">—</span>
              return (
                <span>
                  {ids.map((id, i) => (
                    <span key={id}>
                      {i > 0 ? ", " : ""}
                      <Link className="underline" to={`/app/{{ f.relation_target_kebab }}/${id}`}>
                        {labels[i] ?? id}
                      </Link>
                    </span>
                  ))}
                </span>
              )
            })()}
          </span>
        </div>
{%- else %}
        <div className="grid grid-cols-[160px_1fr] gap-2 text-sm">
          <span className="text-muted-foreground">{{ f.label }}</span>
          <span>
            {formatFieldValue(data.{{ f.leaf }}, {
              kind: "{{ f.kind }}",
{%- if f.widget %}
              widget: "{{ f.widget }}",
{%- endif %}
{%- if f.format %}
              format: "{{ f.format }}",
{%- endif %}
            })}
          </span>
        </div>
{%- endif %}
{%- endfor %}
        <div className="pt-4">
          <Button asChild>
            <Link to={`/app/{{ entity.kebab }}/${data.id}/edit`}>Edit</Link>
          </Button>
        </div>
      </CardContent>
    </Card>
  )
}
