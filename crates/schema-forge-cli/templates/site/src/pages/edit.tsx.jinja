      }
{%- endif %}
{%- endfor %}
      if (isEdit && id) return update{{ entity.pascal }}(id, payload as Partial<{{ entity.pascal }}>)
      return create{{ entity.pascal }}(payload as Partial<{{ entity.pascal }}>)
    },
    onSuccess: (saved) => {
