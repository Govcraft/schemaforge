  }, [data])

  const form = useForm<{{ entity.pascal }}FormValues>({
    resolver: zodResolver({{ entity.snake }}Schema),
    defaultValues: initialValues,
    values: initialValues,
  })

  const mutation = useMutation({
    mutationFn: async (values: {{ entity.pascal }}FormValues) => {
      // Normalize: convert datetime-local strings ("YYYY-MM-DDTHH:MM") to
      // full ISO-8601 with timezone, and drop empty optional fields so the
      // backend doesn't receive blank strings for unset optionals.
      const payload: Record<string, unknown> = { ...values }
{%- for f in entity.fields %}
{%- if f.kind == "datetime" %}
      if (payload["{{ f.name }}"]) {
        const _d = new Date(payload["{{ f.name }}"] as string)
        if (!isNaN(_d.getTime())) payload["{{ f.name }}"] = _d.toISOString()
      } else {
        delete payload["{{ f.name }}"]
      }
{%- elif not f.required %}
      if (payload["{{ f.name }}"] === "" || payload["{{ f.name }}"] === undefined || payload["{{ f.name }}"] === null) {
