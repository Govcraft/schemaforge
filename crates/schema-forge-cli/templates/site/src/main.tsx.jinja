import React from "react"
import ReactDOM from "react-dom/client"
import { BrowserRouter } from "react-router-dom"
import {
  MutationCache,
  QueryCache,
  QueryClient,
  QueryClientProvider,
} from "@tanstack/react-query"
import { toast } from "sonner"
import App from "./App"
import { ensureRefreshScheduled } from "./lib/auth"
import "./index.css"

// Re-arm the PASETO refresh timer for any token that survived a full
// page reload. No-op when no token is stored.
ensureRefreshScheduled()

// Route every uncaught query/mutation error to a toast so pages don't
// have to wire per-call error handling. 401s are handled in the
// api-client's refresh-and-retry path and surface as a redirect
// instead of a toast; they reach this cache only as a final fallback.
const queryClient = new QueryClient({
  queryCache: new QueryCache({
    onError: (error) => {
      toast.error(`Load failed: ${error instanceof Error ? error.message : String(error)}`)
    },
  }),
  mutationCache: new MutationCache({
    onError: (error) => {
      toast.error(`Action failed: ${error instanceof Error ? error.message : String(error)}`)
    },
  }),
})

ReactDOM.createRoot(document.getElementById("root") as HTMLElement).render(
  <React.StrictMode>
    <QueryClientProvider client={queryClient}>
      <BrowserRouter>
        <App />
      </BrowserRouter>
    </QueryClientProvider>
  </React.StrictMode>,
)
